script-source,457,node:internal/assert/assertion_error,'use strict';\x0d\n\x0d\nconst {\x0d\n  ArrayPrototypeJoin\x2C\x0d\n  ArrayPrototypePop\x2C\x0d\n  Error\x2C\x0d\n  ErrorCaptureStackTrace\x2C\x0d\n  MathMax\x2C\x0d\n  ObjectCreate\x2C\x0d\n  ObjectDefineProperty\x2C\x0d\n  ObjectGetPrototypeOf\x2C\x0d\n  ObjectKeys\x2C\x0d\n  String\x2C\x0d\n  StringPrototypeEndsWith\x2C\x0d\n  StringPrototypeRepeat\x2C\x0d\n  StringPrototypeSlice\x2C\x0d\n  StringPrototypeSplit\x2C\x0d\n} = primordials;\x0d\n\x0d\nconst { inspect } = require('internal/util/inspect');\x0d\nconst {\x0d\n  removeColors\x2C\x0d\n} = require('internal/util');\x0d\nconst colors = require('internal/util/colors');\x0d\nconst {\x0d\n  validateObject\x2C\x0d\n} = require('internal/validators');\x0d\nconst { isErrorStackTraceLimitWritable } = require('internal/errors');\x0d\n\x0d\n\x0d\nconst kReadableOperator = {\x0d\n  deepStrictEqual: 'Expected values to be strictly deep-equal:'\x2C\x0d\n  strictEqual: 'Expected values to be strictly equal:'\x2C\x0d\n  strictEqualObject: 'Expected "actual" to be reference-equal to "expected":'\x2C\x0d\n  deepEqual: 'Expected values to be loosely deep-equal:'\x2C\x0d\n  notDeepStrictEqual: 'Expected "actual" not to be strictly deep-equal to:'\x2C\x0d\n  notStrictEqual: 'Expected "actual" to be strictly unequal to:'\x2C\x0d\n  notStrictEqualObject:\x0d\n    'Expected "actual" not to be reference-equal to "expected":'\x2C\x0d\n  notDeepEqual: 'Expected "actual" not to be loosely deep-equal to:'\x2C\x0d\n  notIdentical: 'Values have same structure but are not reference-equal:'\x2C\x0d\n  notDeepEqualUnequal: 'Expected values not to be loosely deep-equal:'\x2C\x0d\n};\x0d\n\x0d\n// Comparing short primitives should just show === / !== instead of using the\x0d\n// diff.\x0d\nconst kMaxShortLength = 12;\x0d\n\x0d\nfunction copyError(source) {\x0d\n  const keys = ObjectKeys(source);\x0d\n  const target = ObjectCreate(ObjectGetPrototypeOf(source));\x0d\n  for (const key of keys) {\x0d\n    target[key] = source[key];\x0d\n  }\x0d\n  ObjectDefineProperty(target\x2C 'message'\x2C { __proto__: null\x2C value: source.message });\x0d\n  return target;\x0d\n}\x0d\n\x0d\nfunction inspectValue(val) {\x0d\n  // The util.inspect default values could be changed. This makes sure the\x0d\n  // error messages contain the necessary information nevertheless.\x0d\n  return inspect(\x0d\n    val\x2C\x0d\n    {\x0d\n      compact: false\x2C\x0d\n      customInspect: false\x2C\x0d\n      depth: 1000\x2C\x0d\n      maxArrayLength: Infinity\x2C\x0d\n      // Assert compares only enumerable properties (with a few exceptions).\x0d\n      showHidden: false\x2C\x0d\n      // Assert does not detect proxies currently.\x0d\n      showProxy: false\x2C\x0d\n      sorted: true\x2C\x0d\n      // Inspect getters as we also check them when comparing entries.\x0d\n      getters: true\x2C\x0d\n    }\x2C\x0d\n  );\x0d\n}\x0d\n\x0d\nfunction createErrDiff(actual\x2C expected\x2C operator) {\x0d\n  let other = '';\x0d\n  let res = '';\x0d\n  let end = '';\x0d\n  let skipped = false;\x0d\n  const actualInspected = inspectValue(actual);\x0d\n  const actualLines = StringPrototypeSplit(actualInspected\x2C '\\n');\x0d\n  const expectedLines = StringPrototypeSplit(inspectValue(expected)\x2C '\\n');\x0d\n\x0d\n  let i = 0;\x0d\n  let indicator = '';\x0d\n\x0d\n  // In case both values are objects or functions explicitly mark them as not\x0d\n  // reference equal for the `strictEqual` operator.\x0d\n  if (operator === 'strictEqual' &&\x0d\n      ((typeof actual === 'object' && actual !== null &&\x0d\n        typeof expected === 'object' && expected !== null) ||\x0d\n       (typeof actual === 'function' && typeof expected === 'function'))) {\x0d\n    operator = 'strictEqualObject';\x0d\n  }\x0d\n\x0d\n  // If "actual" and "expected" fit on a single line and they are not strictly\x0d\n  // equal\x2C check further special handling.\x0d\n  if (actualLines.length === 1 && expectedLines.length === 1 &&\x0d\n    actualLines[0] !== expectedLines[0]) {\x0d\n    // Check for the visible length using the `removeColors()` function\x2C if\x0d\n    // appropriate.\x0d\n    const c = inspect.defaultOptions.colors;\x0d\n    const actualRaw = c ? removeColors(actualLines[0]) : actualLines[0];\x0d\n    const expectedRaw = c ? removeColors(expectedLines[0]) : expectedLines[0];\x0d\n    const inputLength = actualRaw.length + expectedRaw.length;\x0d\n    // If the character length of "actual" and "expected" together is less than\x0d\n    // kMaxShortLength and if neither is an object and at least one of them is\x0d\n    // not `zero`\x2C use the strict equal comparison to visualize the output.\x0d\n    if (inputLength <= kMaxShortLength) {\x0d\n      if ((typeof actual !== 'object' || actual === null) &&\x0d\n          (typeof expected !== 'object' || expected === null) &&\x0d\n          (actual !== 0 || expected !== 0)) { // -0 === +0\x0d\n        return `${kReadableOperator[operator]}\\n\\n` +\x0d\n            `${actualLines[0]} !== ${expectedLines[0]}\\n`;\x0d\n      }\x0d\n    } else if (operator !== 'strictEqualObject') {\x0d\n      // If the stderr is a tty and the input length is lower than the current\x0d\n      // columns per line\x2C add a mismatch indicator below the output. If it is\x0d\n      // not a tty\x2C use a default value of 80 characters.\x0d\n      const maxLength = process.stderr.isTTY ? process.stderr.columns : 80;\x0d\n      if (inputLength < maxLength) {\x0d\n        while (actualRaw[i] === expectedRaw[i]) {\x0d\n          i++;\x0d\n        }\x0d\n        // Ignore the first characters.\x0d\n        if (i > 2) {\x0d\n          // Add position indicator for the first mismatch in case it is a\x0d\n          // single line and the input length is less than the column length.\x0d\n          indicator = `\\n  ${StringPrototypeRepeat(' '\x2C i)}^`;\x0d\n          i = 0;\x0d\n        }\x0d\n      }\x0d\n    }\x0d\n  }\x0d\n\x0d\n  // Remove all ending lines that match (this optimizes the output for\x0d\n  // readability by reducing the number of total changed lines).\x0d\n  let a = actualLines[actualLines.length - 1];\x0d\n  let b = expectedLines[expectedLines.length - 1];\x0d\n  while (a === b) {\x0d\n    if (i++ < 3) {\x0d\n      end = `\\n  ${a}${end}`;\x0d\n    } else {\x0d\n      other = a;\x0d\n    }\x0d\n    ArrayPrototypePop(actualLines);\x0d\n    ArrayPrototypePop(expectedLines);\x0d\n    if (actualLines.length === 0 || expectedLines.length === 0)\x0d\n      break;\x0d\n    a = actualLines[actualLines.length - 1];\x0d\n    b = expectedLines[expectedLines.length - 1];\x0d\n  }\x0d\n\x0d\n  const maxLines = MathMax(actualLines.length\x2C expectedLines.length);\x0d\n  // Strict equal with identical objects that are not identical by reference.\x0d\n  // E.g.\x2C assert.deepStrictEqual({ a: Symbol() }\x2C { a: Symbol() })\x0d\n  if (maxLines === 0) {\x0d\n    // We have to get the result again. The lines were all removed before.\x0d\n    const actualLines = StringPrototypeSplit(actualInspected\x2C '\\n');\x0d\n\x0d\n    // Only remove lines in case it makes sense to collapse those.\x0d\n    // TODO: Accept env to always show the full error.\x0d\n    if (actualLines.length > 50) {\x0d\n      actualLines[46] = `${colors.blue}...${colors.white}`;\x0d\n      while (actualLines.length > 47) {\x0d\n        ArrayPrototypePop(actualLines);\x0d\n      }\x0d\n    }\x0d\n\x0d\n    return `${kReadableOperator.notIdentical}\\n\\n` +\x0d\n           `${ArrayPrototypeJoin(actualLines\x2C '\\n')}\\n`;\x0d\n  }\x0d\n\x0d\n  // There were at least five identical lines at the end. Mark a couple of\x0d\n  // skipped.\x0d\n  if (i >= 5) {\x0d\n    end = `\\n${colors.blue}...${colors.white}${end}`;\x0d\n    skipped = true;\x0d\n  }\x0d\n  if (other !== '') {\x0d\n    end = `\\n  ${other}${end}`;\x0d\n    other = '';\x0d\n  }\x0d\n\x0d\n  let printedLines = 0;\x0d\n  let identical = 0;\x0d\n  const msg = kReadableOperator[operator] +\x0d\n        `\\n${colors.green}+ actual${colors.white} ${colors.red}- expected${colors.white}`;\x0d\n  const skippedMsg = ` ${colors.blue}...${colors.white} Lines skipped`;\x0d\n\x0d\n  let lines = actualLines;\x0d\n  let plusMinus = `${colors.green}+${colors.white}`;\x0d\n  let maxLength = expectedLines.length;\x0d\n  if (actualLines.length < maxLines) {\x0d\n    lines = expectedLines;\x0d\n    plusMinus = `${colors.red}-${colors.white}`;\x0d\n    maxLength = actualLines.length;\x0d\n  }\x0d\n\x0d\n  for (i = 0; i < maxLines; i++) {\x0d\n    if (maxLength < i + 1) {\x0d\n      // If more than two former lines are identical\x2C print them. Collapse them\x0d\n      // in case more than five lines were identical.\x0d\n      if (identical > 2) {\x0d\n        if (identical > 3) {\x0d\n          if (identical > 4) {\x0d\n            if (identical === 5) {\x0d\n              res += `\\n  ${lines[i - 3]}`;\x0d\n              printedLines++;\x0d\n            } else {\x0d\n              res += `\\n${colors.blue}...${colors.white}`;\x0d\n              skipped = true;\x0d\n            }\x0d\n          }\x0d\n          res += `\\n  ${lines[i - 2]}`;\x0d\n          printedLines++;\x0d\n        }\x0d\n        res += `\\n  ${lines[i - 1]}`;\x0d\n        printedLines++;\x0d\n      }\x0d\n      // No identical lines before.\x0d\n      identical = 0;\x0d\n      // Add the expected line to the cache.\x0d\n      if (lines === actualLines) {\x0d\n        res += `\\n${plusMinus} ${lines[i]}`;\x0d\n      } else {\x0d\n        other += `\\n${plusMinus} ${lines[i]}`;\x0d\n      }\x0d\n      printedLines++;\x0d\n    // Only extra actual lines exist\x0d\n    // Lines diverge\x0d\n    } else {\x0d\n      const expectedLine = expectedLines[i];\x0d\n      let actualLine = actualLines[i];\x0d\n      // If the lines diverge\x2C specifically check for lines that only diverge by\x0d\n      // a trailing comma. In that case it is actually identical and we should\x0d\n      // mark it as such