expectedLine}`;\x0d\n        printedLines += 2;\x0d\n      // Lines are identical\x0d\n      } else {\x0d\n        // Add all cached information to the result before adding other things\x0d\n        // and reset the cache.\x0d\n        res += other;\x0d\n        other = '';\x0d\n        identical++;\x0d\n        // The very first identical line since the last diverging line is be\x0d\n        // added to the result.\x0d\n        if (identical <= 2) {\x0d\n          res += `\\n  ${actualLine}`;\x0d\n          printedLines++;\x0d\n        }\x0d\n      }\x0d\n    }\x0d\n    // Inspected object to big (Show ~50 rows max)\x0d\n    if (printedLines > 50 && i < maxLines - 2) {\x0d\n      return `${msg}${skippedMsg}\\n${res}\\n${colors.blue}...${colors.white}${other}\\n` +\x0d\n             `${colors.blue}...${colors.white}`;\x0d\n    }\x0d\n  }\x0d\n\x0d\n  return `${msg}${skipped ? skippedMsg : ''}\\n${res}${other}${end}${indicator}`;\x0d\n}\x0d\n\x0d\nfunction addEllipsis(string) {\x0d\n  const lines = StringPrototypeSplit(string\x2C '\\n'\x2C 11);\x0d\n  if (lines.length > 10) {\x0d\n    lines.length = 10;\x0d\n    return `${ArrayPrototypeJoin(lines\x2C '\\n')}\\n...`;\x0d\n  } else if (string.length > 512) {\x0d\n    return `${StringPrototypeSlice(string\x2C 512)}...`;\x0d\n  }\x0d\n  return string;\x0d\n}\x0d\n\x0d\nclass AssertionError extends Error {\x0d\n  constructor(options) {\x0d\n    validateObject(options\x2C 'options');\x0d\n    const {\x0d\n      message\x2C\x0d\n      operator\x2C\x0d\n      stackStartFn\x2C\x0d\n      details\x2C\x0d\n      // Compatibility with older versions.\x0d\n      stackStartFunction\x2C\x0d\n    } = options;\x0d\n    let {\x0d\n      actual\x2C\x0d\n      expected\x2C\x0d\n    } = options;\x0d\n\x0d\n    const limit = Error.stackTraceLimit;\x0d\n    if (isErrorStackTraceLimitWritable()) Error.stackTraceLimit = 0;\x0d\n\x0d\n    if (message != null) {\x0d\n      super(String(message));\x0d\n    } else {\x0d\n      // Reset colors on