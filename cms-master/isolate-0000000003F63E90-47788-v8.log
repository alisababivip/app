script-source,466,node:internal/assert/calltracker,'use strict';\x0d\n\x0d\nconst {\x0d\n  ArrayPrototypePush\x2C\x0d\n  ArrayPrototypeSlice\x2C\x0d\n  Error\x2C\x0d\n  FunctionPrototype\x2C\x0d\n  ObjectFreeze\x2C\x0d\n  Proxy\x2C\x0d\n  ReflectApply\x2C\x0d\n  SafeSet\x2C\x0d\n  SafeWeakMap\x2C\x0d\n} = primordials;\x0d\n\x0d\nconst {\x0d\n  codes: {\x0d\n    ERR_UNAVAILABLE_DURING_EXIT\x2C\x0d\n    ERR_INVALID_ARG_VALUE\x2C\x0d\n  }\x2C\x0d\n} = require('internal/errors');\x0d\nconst AssertionError = require('internal/assert/assertion_error');\x0d\nconst {\x0d\n  validateUint32\x2C\x0d\n} = require('internal/validators');\x0d\n\x0d\nconst noop = FunctionPrototype;\x0d\n\x0d\nclass CallTrackerContext {\x0d\n  #expected;\x0d\n  #calls;\x0d\n  #name;\x0d\n  #stackTrace;\x0d\n  constructor({ expected\x2C stackTrace\x2C name }) {\x0d\n    this.#calls = [];\x0d\n    this.#expected = expected;\x0d\n    this.#stackTrace = stackTrace;\x0d\n    this.#name = name;\x0d\n  }\x0d\n\x0d\n  track(thisArg\x2C args) {\x0d\n    const argsClone = ObjectFreeze(ArrayPrototypeSlice(args));\x0d\n    ArrayPrototypePush(this.#calls\x2C ObjectFreeze({ thisArg\x2C arguments: argsClone }));\x0d\n  }\x0d\n\x0d\n  get delta() {\x0d\n    return this.#calls.length - this.#expected;\x0d\n  }\x0d\n\x0d\n  reset() {\x0d\n    this.#calls = [];\x0d\n  }\x0d\n  getCalls() {\x0d\n    return ObjectFreeze(ArrayPrototypeSlice(this.#calls));\x0d\n  }\x0d\n\x0d\n  report() {\x0d\n    if (this.delta !== 0) {\x0d\n      const message = `Expected the ${this.#name} function to be ` +\x0d\n                      `executed ${this.#expected} time(s) but was ` +\x0d\n                      `executed ${this.#calls.length} time(s).`;\x0d\n      return {\x0d\n        message\x2C\x0d\n        actual: this.#calls.length\x2C\x0d\n        expected: this.#expected\x2C\x0d\n        operator: this.#name\x2C\x0d\n        stack: this.#stackTrace\x2C\x0d\n      };\x0d\n    }\x0d\n  }\x0d\n}\x0d\n\x0d\nclass CallTracker {\x0d\n\x0d\n  #callChecks = new SafeSet();\x0d\n  #trackedFunctions = new SafeWeakMap();\x0d\n\x0d\n  #getTrackedFunction(tracked) {\x0d\n    if (!this.#trackedFunctions.has(tracked)) {\x0d\n      throw new ERR_INVALID_ARG_VALUE('tracked'\x2C tracked\x2C 'is not a tracked function');\x0d\n    }\x0d\n    return this.#trackedFunctions.get(tracked);\x0d\n  }\x0d\n\x0d\n  reset(tracked) {\x0d\n    if (tracked === undefined) {\x0d\n      this.#callChecks.forEach((check) => check.reset());\x0d\n      return;\x0d\n    }\x0d\n\x0d\n    this.#getTrackedFunction(tracked).reset();\x0d\n  }\x0d\n\x0d\n  getCalls(tracked) {\x0d\n    return this.#getTrackedFunction(tracked).getCalls();\x0d\n  }\x0d\n\x0d\n  calls(fn\x2C expected = 1) {\x0d\n    if (process._exiting)\x0d\n      throw new ERR_UNAVAILABLE_DURING_EXIT();\x0d\n    if (typeof fn === 'number') {\x0d\n      expected = fn;\x0d\n      fn = noop;\x0d\n    } else if (fn === undefined) {\x0d\n      fn = noop;\x0d\n    }\x0d\n\x0d\n    validateUint32(expected\x2C 'expected'\x2C true);\x0d\n\x0d\n    const context = new CallTrackerContext({\x0d\n      expected\x2C\x0d\n      // eslint-disable-next-line no-restricted-syntax\x0d\n      stackTrace: new Error()\x2C\x0d\n      name: fn.name || 'calls'\x2C\x0d\n    });\x0d\n    const tracked = new Proxy(fn\x2C {\x0d\n      __proto__: null\x2C\x0d\n      apply(fn\x2C thisArg\x2C argList) {\x0d\n        context.track(thisArg\x2C argList);\x0d\n        return ReflectApply(fn\x2C thisArg\x2C argList);\x0d\n      }\x2C\x0d\n    });\x0d\n    this.#callChecks.add(context);\x0d\n    this.#trackedFunctions.set(tracked\x2C context);\x0d\n    return tracked;\x0d\n  }\x0d\n\x0d\n  report() {\x0d\n    const errors = [];\x0d\n    for (const context of this.#callChecks) {\x0d\n      const message = context.report();\x0d\n      if (message !== undefined) {\x0d\n        ArrayPrototypePush(errors\x2C message);\x0d\n      }\x0d\n    }\x0d\n    return errors;\x0d\n  }\x0d\n\x0d\n  verify() {\x0d\n    const errors = this.report();\x0d\n    if (errors.length === 0) {\x0d\n      return;\x0d\n    }\x0d\n    const message = errors.length === 1 ?\x0d\n      errors[0].message :\x0d\n      'Functions were not called the expected number of times';\x0d\n    throw new AssertionError({\x0d\n      message\x2C\x0d\n      details: errors\x2C\x0d\n    });\x0d\n  }\x0d\n}\x0d\n\x0d\nmodule.exports = CallTracker;\x0d\n
