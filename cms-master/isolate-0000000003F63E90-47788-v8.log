 innerFail({\x0d\n      actual\x2C\x0d\n      expected: error\x2C\x0d\n      operator: stackStartFn.name\x2C\x0d\n      message: `Got unwanted ${fnType}${details}\\n` +\x0d\n               `Actual message: "${actual && actual.message}"`\x2C\x0d\n      stackStartFn\x2C\x0d\n    });\x0d\n  }\x0d\n  throw actual;\x0d\n}\x0d\n\x0d\n/**\x0d\n * Expects the function `promiseFn` to throw an error.\x0d\n * @param {() => any} promiseFn\x0d\n * @param {...any} [args]\x0d\n * @returns {void}\x0d\n */\x0d\nassert.throws = function throws(promiseFn\x2C ...args) {\x0d\n  expectsError(throws\x2C getActual(promiseFn)\x2C ...args);\x0d\n};\x0d\n\x0d\n/**\x0d\n * Expects `promiseFn` function or its value to reject.\x0d\n * @param {() => Promise<any>} promiseFn\x0d\n * @param {...any} [args]\x0d\n * @returns {Promise<void>}\x0d\n */\x0d\nassert.rejects = async function rejects(promiseFn\x2C ...args) {\x0d\n  expectsError(rejects\x2C await waitForActual(promiseFn)\x2C ...args);\x0d\n};\x0d\n\x0d\n/**\x0d\n * Asserts that the function `fn` does not throw an error.\x0d\n * @param {() => any} fn\x0d\n * @param {...any} [args]\x0d\n * @returns {void}\x0d\n */\x0d\nassert.doesNotThrow = function doesNotThrow(fn\x2C ...args) {\x0d\n  expectsNoError(doesNotThrow\x2C getActual(fn)\x2C ...args);\x0d\n};\x0d\n\x0d\n/**\x0d\n * Expects `fn` or its value to not reject.\x0d\n * @param {() => Promise<any>} fn\x0d\n * @param {...any} [args]\x0d\n * @returns {Promise<void>}\x0d\n */\x0d\nassert.doesNotReject = async function doesNotReject(fn\x2C ...args) {\x0d\n  expectsNoError(doesNotReject\x2C await waitForActual(fn)\x2C ...args);\x0d\n};\x0d\n\x0d\n/**\x0d\n * Throws `value` if the value is not `null` or `undefined`.\x0d\n * @param {any} err\x0d\n * @returns {void}\x0d\n */\x0d\nassert.ifError = function ifError(err) {\x0d\n  if (err !== null && err !== undefined) {\x0d\n    let message = 'ifError got unwanted exception: ';\x0d\n    if (typeof err === 'object' && typeof err.message === 'string') {\x0d\n      if (err.message.length === 0 && err.constructor) {\x0d\n        message += err.constructor.name;\x0d\n      } else {\x0d\n        message += err.message;\x0d\n      }\x0d\n    } else {\x0d\n      message += inspect(err);\x0d\n    }\x0d\n\x0d\n    const newErr = new AssertionError({\x0d\n      actual: err\x2C\x0d\n      expected: null\x2C\x0d\n      operator: 'ifError'\x2C\x0d\n      message\x2C\x0d\n      stackStartFn: ifError\x2C\x0d\n    });\x0d\n\x0d\n    // Make sure we actually have a stack trace!\x0d\n    const origStack = err.stack;\x0d\n\x0d\n    if (typeof origStack === 'string') {\x0d\n      // This will remove any duplicated frames from the error frames taken\x0d\n      // from within `ifError` and add the original error frames to the newly\x0d\n      // created ones.\x0d\n      const origStackStart = StringPrototypeIndexOf(origStack\x2C '\\n    at');\x0d\n      if (origStackStart !== -1) {\x0d\n        const originalFrames = StringPrototypeSplit(\x0d\n          StringPrototypeSlice(origStack\x2C origStackStart + 1)\x2C\x0d\n          '\\n'\x2C\x0d\n        );\x0d\n        // Filter all frames existing in err.stack.\x0d\n        let newFrames = StringPrototypeSplit(newErr.stack\x2C '\\n');\x0d\n        for (const errFrame of originalFrames) {\x0d\n          // Find the first occurrence of the frame.\x0d\n          const pos = ArrayPrototypeIndexOf(newFrames\x2C errFrame);\x0d\n          if (pos !== -1) {\x0d\n            // Only keep new frames.\x0d\n            newFrames = ArrayPrototypeSlice(newFrames\x2C 0\x2C pos);\x0d\n            break;\x0d\n          }\x0d\n        }\x0d\n        const stackStart = ArrayPrototypeJoin(newFrames\x2C '\\n');\x0d\n        const stackEnd = ArrayPrototypeJoin(originalFrames\x2C '\\n');\x0d\n        newErr.stack = `${stackStart}\\n${stackEnd}`;\x0d\n      }\x0d\n    }\x0d\n\x0d\n    throw newErr;\x0d\n  }\x0d\n};\x0d\n\x0d\nfunction internalMatch(string\x2C regexp\x2C message\x2C fn) {\x0d\n  if (!isRegExp(regexp)) {\x0d\n    throw new ERR_INVALID_ARG_TYPE(\x0d\n      'regexp'\x2C 'RegExp'\x2C regexp\x2C\x0d\n    );\x0d\n  }\x0d\n  const match = fn === assert.match;\x0d\n  if (typeof string !== 'string' ||\x0d\n      RegExpPrototypeExec(regexp\x2C string) !== null !== match) {\x0d\n    if (message instanceof Error) {\x0d\n      throw message;\x0d\n    }\x0d\n\x0d\n    const generatedMessage = !message;\x0d\n\x0d\n    // 'The input was expected to not match the regular expression ' +\x0d\n    message = message || (typeof string !== 'string' ?\x0d\n      'The "string" argument must be of type string. Received type ' +\x0d\n        `${typeof string} (${inspect(string)})` :\x0d\n      (match ?\x0d\n        'The input did not match the regular expression ' :\x0d\n        'The input was expected to not match the regular expression ') +\x0d\n          `${inspect(regexp)}. Input:\\n\\n${inspect(string)}\\n`);\x0d\n    const err = new AssertionError({\x0d\n      actual: string\x2C\x0d\n      expected: regexp\x2C\x0d\n      message\x2C\x0d\n      operator: fn.name\x2C\x0d\n      stackStartFn: fn\x2C\x0d\n    });\x0d\n    err.generatedMessage = generatedMessage;\x0d\n    throw err;\x0d\n  }\x0d\n}\x0d\n\x0d\n/**\x0d\n * Expects the `string` input to match the regular expression.\x0d\n * @param {string} string\x0d\n * @param {RegExp} regexp\x0d\n * @param {string | Error} [message]\x0d\n * @returns {void}\x0d\n */\x0d\nassert.match = function match(string\x2C regexp\x2C message) {\x0d\n  internalMatch(string\x2C regexp\x2C message\x2C match);\x0d\n};\x0d\n\x0d\n/**\x0d\n * Expects the `string` input not to match the regular expression.\x0d\n * @param {string} string\x0d\n * @param {RegExp} regexp\x0d\n * @param {string | Error} [message]\x0d\n * @returns {void}\x0d\n */\x0d\nassert.doesNotMatch = function doesNotMatch(string\x2C regexp\x2C message) {\x0d\n  internalMatch(string\x2C regexp\x2C message\x2C doesNotMatch);\x0d\n};\x0d\n\x0d\nassert.CallTracker = CallTracker;\x0d\n\x0d\n/