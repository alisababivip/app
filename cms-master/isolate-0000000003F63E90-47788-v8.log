script-source,464,node:internal/perf/performance_entry,'use strict';\x0d\n\x0d\nconst {\x0d\n  ObjectSetPrototypeOf\x2C\x0d\n  Symbol\x2C\x0d\n} = primordials;\x0d\n\x0d\nconst {\x0d\n  codes: {\x0d\n    ERR_ILLEGAL_CONSTRUCTOR\x2C\x0d\n  }\x2C\x0d\n} = require('internal/errors');\x0d\n\x0d\nconst {\x0d\n  customInspectSymbol: kInspect\x2C\x0d\n} = require('internal/util');\x0d\n\x0d\nconst { inspect } = require('util');\x0d\n\x0d\nconst kName = Symbol('kName');\x0d\nconst kType = Symbol('kType');\x0d\nconst kStart = Symbol('kStart');\x0d\nconst kDuration = Symbol('kDuration');\x0d\nconst kDetail = Symbol('kDetail');\x0d\n\x0d\nfunction isPerformanceEntry(obj) {\x0d\n  return obj?.[kName] !== undefined;\x0d\n}\x0d\n\x0d\nclass PerformanceEntry {\x0d\n  constructor() {\x0d\n    throw new ERR_ILLEGAL_CONSTRUCTOR();\x0d\n  }\x0d\n\x0d\n  get name() { return this[kName]; }\x0d\n\x0d\n  get entryType() { return this[kType]; }\x0d\n\x0d\n  get startTime() { return this[kStart]; }\x0d\n\x0d\n  get duration() { return this[kDuration]; }\x0d\n\x0d\n  get detail() { return this[kDetail]; }\x0d\n\x0d\n  [kInspect](depth\x2C options) {\x0d\n    if (depth < 0) return this;\x0d\n\x0d\n    const opts = {\x0d\n      ...options\x2C\x0d\n      depth: options.depth == null ? null : options.depth - 1\x2C\x0d\n    };\x0d\n\x0d\n    return `${this.constructor.name} ${inspect(this.toJSON()\x2C opts)}`;\x0d\n  }\x0d\n\x0d\n  toJSON() {\x0d\n    return {\x0d\n      name: this.name\x2C\x0d\n      entryType: this.entryType\x2C\x0d\n      startTime: this.startTime\x2C\x0d\n      duration: this.duration\x2C\x0d\n      detail: this.detail\x2C\x0d\n    };\x0d\n  }\x0d\n}\x0d\n\x0d\nclass InternalPerformanceEntry {\x0d\n  constructor(name\x2C type\x2C start\x2C duration\x2C detail) {\x0d\n    this[kName] = name;\x0d\n    this[kType] = type;\x0d\n    this[kStart] = start;\x0d\n    this[kDuration] = duration;\x0d\n    this[kDetail] = detail;\x0d\n  }\x0d\n}\x0d\n\x0d\nInternalPerformanceEntry.prototype.constructor = PerformanceEntry;\x0d\nObjectSetPrototypeOf(\x0d\n  InternalPerformanceEntry.prototype\x2C\x0d\n  PerformanceEntry.prototype);\x0d\n\x0d\nmodule.exports = {\x0d\n  InternalPerformanceEntry\x2C\x0d\n  PerformanceEntry\x2C\x0d\n  isPerformanceEntry\x2C\x0d\n};\x0d\n
