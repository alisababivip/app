VISED OF THE POSSIBILITY OF SUCH DAMAGE.\x0d\n */\x0d\n\x0d\n'use strict';\x0d\n\x0d\nconst {\x0d\n  ArrayIsArray\x2C\x0d\n  ArrayPrototypePush\x2C\x0d\n  ArrayPrototypeSlice\x2C\x0d\n  ArrayPrototypeSort\x2C\x0d\n  ObjectPrototypeHasOwnProperty\x2C\x0d\n  StringPrototypeCharAt\x2C\x0d\n} = primordials;\x0d\n\x0d\nconst { validateObject } = require('internal/validators');\x0d\n\x0d\nlet base64Map;\x0d\n\x0d\nconst VLQ_BASE_SHIFT = 5;\x0d\nconst VLQ_BASE_MASK = (1 << 5) - 1;\x0d\nconst VLQ_CONTINUATION_MASK = 1 << 5;\x0d\n\x0d\nclass StringCharIterator {\x0d\n  /**\x0d\n   * @constructor\x0d\n   * @param {string} string\x0d\n   */\x0d\n  constructor(string) {\x0d\n    this._string = string;\x0d\n    this._position = 0;\x0d\n  }\x0d\n\x0d\n  /**\x0d\n   * @return {string}\x0d\n   */\x0d\n  next() {\x0d\n    return StringPrototypeCharAt(this._string\x2C this._position++);\x0d\n  }\x0d\n\x0d\n  /**\x0d\n   * @return {string}\x0d\n   */\x0d\n  peek() {\x0d\n    return StringPrototypeCharAt(this._string\x2C this._position);\x0d\n  }\x0d\n\x0d\n  /**\x0d\n   * @return {boolean}\x0d\n   */\x0d\n  hasNext() {\x0d\n    return this._position < this._string.length;\x0d\n  }\x0d\n}\x0d\n\x0d\n/**\x0d\n * Implements Source Map V3 model.\x0d\n * See https://github.com/google/closure-compiler/wiki/Source-Maps\x0d\n * for format description.\x0d\n */\x0d\nclass SourceMap {\x0d\n  #payload;\x0d\n  #mappings = [];\x0d\n  #sources = {};\x0d\n  #sourceContentByURL = {};\x0d\n\x0d\n  /**\x0d\n   * @constructor\x0d\n   * @param {SourceMapV3} payload\x0d\n   */\x0d\n  constructor(payload) {\x0d\n    if (!base64Map) {\x0d\n      const base64Digits =\x0d\n             'ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789+/';\x0d\n      base64Map = {};\x0d\n      for (let i = 0; i < base64Digits.length; ++i)\x0d\n        base64Map[base64Digits[i]] = i;\x0d\n    }\x0d\n    this.#payload = cloneSourceMapV3(payload);\x0d\n    this.#parseMappingPayload();\x0d\n  }\x0d\n\x0d\n  /**\x0d\n   * @return {object} raw source map v3 payload.\x0d\n   */\x0d\n  get payload() {\x0d\n    return cloneSourceMapV3(this.#payload);\x0d\n  }\x0d\n\x0d\n  #parseMappingPayload = () => {\x0d\n    if (this.#payload.sections) {\x0d\n      this.#parseSections(this.#payload.sections);\x0d\n    } else {\x0d\n      this.#parseMap(this.#payload\x2C 0\x2C 0);\x0d\n    }\x0d\n    ArrayPrototypeSort(this.#mappings\x2C compareSourceMapEntry);\x0d\n  };\x0d\n\x0d\n  /**\x0d\n   * @param {Array.<SourceMapV3.Section>} sections\x0d\n   */\x0d\n  #parseSections = (sections) => {\x0d\n    for (let i = 0; i < sections.length; ++i) {\x0d\n      const section = sections[i];\x0d\n      this.#parseMap(section.map\x2C section.offset.line\x2C section.offset.column);\x0d\n    }\x0d\n  };\x0d\n\x0d\n  /**\x0d\n   * @param {number} lineOffset 0-indexed line offset in compiled resource\x0d\n   * @param {number} columnOffset 0-indexed column offset in compiled resource\x0d\n   * @return {object} representing start of range if found\x2C or empty object\x0d\n   */\x0d\n  findEntry(lineOffset\x2C columnOffset) {\x0d\n    let first = 0;\x0d\n    let count = this.#mappings.length;\x0d\n    while (count > 1) {\x0d\n      const step = count >> 1;\x0d\n      const middle = first + step;\x0d\n      const mapping = this.#mappings[middle];\x0d\n      if (lineOffset < mapping[0] ||\x0d\n          (lineOffset === mapping[0] && columnOffset < mapping[1])) {\x0d\n        count = step;\x0d\n      } else {\x0d\n        first = middle;\x0d\n        count -= step;\x0d\n      }\x0d\n    }\x0d\n    const entry = this.#mappings[first];\x0d\n    if (!first && entry && (lineOffset < entry[0] ||\x0d\n        (lineOffset === entry[0] && columnOffset < entry[1]))) {\x0d\n      return {};\x0d\n    } else if (!entry) {\x0d\n      return {};\x0d\n    }\x0d\n    return {\x0d\n      generatedLine: entry[0]\x2C\x0d\n      generatedColumn: entry[1]\x2C\x0d\n      originalSource: entry[2]\x2C\x0d\n      originalLine: entry[3]\x2C\x0d\n      originalColumn: entry[4]\x2C\x0d\n      name: entry[5]\x2C\x0d\n    };\x0d\n  }\x0d\n\x0d\n  /**\x0d\n   * @param {number} lineNumber 1-indexed line number in compiled resource call site\x0d\n   * @param {number} columnNumber 1-indexed column number in compiled resource call site\x0d\n   * @return {object} representing origin call site if found\x2C or empty object\x0d\n   */\x0d\n  findOrigin(lineNumber\x2C columnNumber) {\x0d\n    const range = this.findEntry(lineNumber - 1\x2C columnNumber - 1);\x0d\n    if (\x0d\n      range.originalSource === undefined ||\x0d\n      range.originalLine === undefined ||\x0d\n      range.originalColumn === undefined ||\x0d\n      range.generatedLine === undefined ||\x0d\n      range.generatedColumn === undefined\x0d\n    ) {\x0d\n      return {};\x0d\n    }\x0d\n    const lineOffset = lineNumber - range.generatedLine;\x0d\n    const columnOffset = columnNumber - range.generatedColumn;\x0d\n    return {\x0d\n      name: range.name\x2C\x0d\n      fileName: range.originalSource\x2C\x0d\n      lineNumber: range.originalLine + lineOffset\x2C\x0d\n      columnNumber: range.originalColumn + columnOffset\x2C\x0d\n    };\x0d\n  }\x0d\n\x0d\n  /**\x0d\n   * @override\x0d\n   */\x0d\n  #parseMap(map\x2C lineNumber\x2C columnNumber) {\x0d\n    let sourceIndex = 0;\x0d\n    let sourceLineNumber = 0;\x0d\n    let sourceColumnNumber = 0;\x0d\n    let nameIndex = 0;\x0d\n\x0d\n    const sources = [];\x0d\n    const originalToCanonicalURLMap = {};\x0d\n    for (let i = 0; i < map.sources.length; ++i) {\x0d\n      const url = map.sources[i];\x0d\n      originalToCanonicalURLMap[url] = url;\x0d\n      ArrayPrototypePush(sources\x2C url);\x0d\n      this.#sources[url] = true;\x0d\n\x0d\n      if (map.sourcesContent && map.sourcesContent[i])\x0d\n        this.#sourceContentByURL[url] = map.sourcesContent[i];\x0d\n    }\x0d\n\x0d\n    const stringCharIterator = new StringCharIterator(map.mappings);\x0d\n    let sourceURL = sources[sourceIndex];\x0d\n    while (true) {\x0d\n      if (stringCharIterator.peek() === '\x2C')\x0d\n        stringCharIterator.next();\x0d\n      else {\x0d\n        while (stringCharIterator.peek() === ';') {\x0d\n          lineNumber += 1;\x0d\n          columnNumber = 0;\x0d\n          stringCharIterator.next();\x0d\n        }\x0d\n        if (!stringCharIterator.hasNext())\x0d\n          break;\x0d\n      }\x0d\n\x0d\n      columnNumber += decodeVLQ(stringCharIterator);\x0d\n      if (isSeparator(stringCharIterator.peek())) {\x0d\n        ArrayPrototypePush(this.#mappings\x2C [lineNumber\x2C columnNumber]);\x0d\n        continue;\x0d\n      }\x0d\n\x0d\n      const sourceIndexDelta = decodeVLQ(stringCharIterator);\x0d\n      if (sourceIndexDelta) {\x0d\n        sourceIndex += sourceIndexDelta;\x0d\n        sourceURL = sources[sourceIndex];\x0d\n      }\x0d\n      sourceLineNumber += decodeVLQ(stringCharIterator);\x0d\n      sourceColumnNumber += decodeVLQ(stringCharIterator);\x0d\n\x0d\n      let name;\x0d\n      if (!isSeparator(stringCharIterator.peek())) {\x0d\n        nameIndex += decodeVLQ(stringCharIterator);\x0d\n        name = map.names?.[nameIndex];\x0d\n      }\x0d\n\x0d\n      ArrayPrototypePush(\x0d\n        this.#mappings\x2C\x0d\n        [lineNumber\x2C columnNumber\x2C sourceURL\x2C sourceLineNumber\x2C\x0d\n         sourceColumnNumber\x2C name]\x2C\x0d\n      );\x0d\n    }\x0d\n  }\x0d\n}\x0d\n\x0d\n/**\x0d\n * @param {string} char\x0d\n * @return {boolean}\x0d\n */\x0d\nfunction isSeparator(char) {\x0d\n  return char === '\x2C' || char === ';';\x0d\n}\x0d\n\x0d\n/**\x0d\n * @param {SourceMap.StringCharIterator} stringCharIterator\x0d\n * @return {number}\x0d\n */\x0d\nfunction decodeVLQ(stringCharIterator) {\x0d\n  // Read unsigned value.\x0d\n  let result = 0;\x0d\n  let shift = 0;\x0d\n  let digit;\x0d\n  do {\x0d\n    digit = base64Map[stringCharIterator.next()];\x0d\n    result += (digit & VLQ_BASE_MASK) << shift;\x0d\n    shift += VLQ_BASE_SHIFT;\x0d\n  } while (digit & VLQ_CONTINUATION_MASK);\x0d\n\x0d\n  // Fix the sign.\x0d\n  const negative = result & 1;\x0d\n  // Use unsigned right shift\x2C so that the 32nd bit is properly shifted to the\x0d\n  // 31st\x2C and the 32nd becomes unset.\x0d\n  result >>>= 1;\x0d\n  if (!negative) {\x0d\n    return result;\x0d\n  }\x0d\n\x0d\n  // We need to OR here to ensure the 32nd bit (the sign bit in an Int32) is\x0d\n  // always set for negative numbers. If `result` were 1\x2C (meaning `negate` is\x0d\n  // true and all other bits were zeros)\x2C `result` would now be 0. But -0\x0d\n  // doesn't flip the 32nd bit as intended. All other numbers will successfully\x0d\n  // set the 32nd bit without issue\x2C so doing this is a noop for them.\x0d\n  return -result | (1 << 31);\x0d\n}\x0d\n\x0d\n/**\x0d\n * @param {SourceMapV3} payload\x0d\n * @return {SourceMapV3}\x0d\n */\x0d\nfunction cloneSourceMapV3(payload) {\x0d\n  validateObject(payload\x2C 'payload');\x0d\n  payload = { ...payload };\x0d\n  for (const key in payload) {\x0d\n    if (ObjectPrototypeHasOwnProperty(payload\x2C key) &&\x0d\n        ArrayIsArray(payload[key])) {\x0d\n      payload[key] = ArrayPrototypeSlice(payload[key]);\x0d\n    }\x0d\n  }\x0d\n  return payload;\x0d\n}\x0d\n\x0d\n/**\x0d\n * @param {Array} entry1 source map entry [lineNumber\x2C columnNumber\x2C sourceURL\x2C\x0d\n *  sourceLineNumber\x2C sourceColumnNumber]\x0d\n * @param {Array} entry2 source map entry.\x0d\n * @return {number}\x0d\n */\x0d\nfunction compareSourceMapEntry(entry1\x2C entry2) {\x0d\n  const { 0: lineNumber1\x2C 1: columnNumber1 } = entry1;\x0d\n  const { 0: lineNumber2\x2C 1: columnNumber2 } = entry2;\x0d\n  if (lineNumber1 !== lineNumber2) {\x0d\n    return lineNumber1 - lineNumber2;\x0d\n  }\x0d\n  return columnNumber1 - columnNumber2;\x0d\n}\x0d\n\x0d\nmodule.exports = {\x0d\n  SourceMap\x2C\x0d\n};\x0d\n
