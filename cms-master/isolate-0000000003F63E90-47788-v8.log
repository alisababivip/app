StringPrototypeReplace\x2C\x0d\n  StringPrototypeSlice\x2C\x0d\n  StringPrototypeSplit\x2C\x0d\n  StringPrototypeStartsWith\x2C\x0d\n} = primordials;\x0d\n\x0d\nconst { Buffer } = require('buffer');\x0d\nconst {\x0d\n  codes: {\x0d\n    ERR_AMBIGUOUS_ARGUMENT\x2C\x0d\n    ERR_INVALID_ARG_TYPE\x2C\x0d\n    ERR_INVALID_ARG_VALUE\x2C\x0d\n    ERR_INVALID_RETURN_VALUE\x2C\x0d\n    ERR_MISSING_ARGS\x2C\x0d\n  }\x2C\x0d\n  isErrorStackTraceLimitWritable\x2C\x0d\n  overrideStackTrace\x2C\x0d\n} = require('internal/errors');\x0d\nconst AssertionError = require('internal/assert/assertion_error');\x0d\nconst { openSync\x2C closeSync\x2C readSync } = require('fs');\x0d\nconst { inspect } = require('internal/util/inspect');\x0d\nconst { isPromise\x2C isRegExp } = require('internal/util/types');\x0d\nconst { EOL } = require('internal/constants');\x0d\nconst { BuiltinModule } = require('internal/bootstrap/realm');\x0d\nconst { isError } = require('internal/util');\x0d\n\x0d\nconst errorCache = new SafeMap();\x0d\nconst CallTracker = require('internal/assert/calltracker');\x0d\nconst {\x0d\n  validateFunction\x2C\x0d\n} = require('internal/validators');\x0d\n\x0d\nlet isDeepEqual;\x0d\nlet isDeepStrictEqual;\x0d\nlet parseExpressionAt;\x0d\nlet findNodeAround;\x0d\nlet tokenizer;\x0d\nlet decoder;\x0d\n\x0d\nfunction lazyLoadComparison() {\x0d\n  const comparison = require('internal/util/comparisons');\x0d\n  isDeepEqual = comparison.isDeepEqual;\x0d\n  isDeepStrictEqual = comparison.isDeepStrictEqual;\x0d\n}\x0d\n\x0d\n// Escape control characters but not \\n and \\t to keep the line breaks and\x0d\n// indentation intact.\x0d\n// eslint-disable-next-line no-control-regex\x0d\nconst escapeSequencesRegExp = /[\\x00-\\x08\\x0b\\x0c\\x0e-\\x1f]/g;\x0d\nconst meta = [\x0d\n  '\\\\u0000'\x2C '\\\\u0001'\x2C '\\\\u0002'\x2C '\\\\u0003'\x2C '\\\\u0004'\x2C\x0d\n  '\\\\u0005'\x2C '\\\\u0006'\x2C '\\\\u0007'\x2C '\\\\b'\x2C ''\x2C\x0d\n  ''\x2C '\\\\u000b'\x2C '\\\\f'\x2C ''\x2C '\\\\u000e'\x2C\x0d\n  '\\\\u000f'\x2C '\\\\u0010'\x2C '\\\\u0011'\x2C '\\\\u0012'\x2C '\\\\u0013'\x2C\x0d\n  '\\\\u0014'\x2C '\\\\u0015'\x2C '\\\\u0016'\x2C '\\\\u0017'\x2C '\\\\u0018'\x2C\x0d\n  '\\\\u0019'\x2C '\\\\u001a'\x2C '\\\\u001b'\x2C '\\\\u001c'\x2C '\\\\u001d'\x2C\x0d\n  '\\\\u001e'\x2C '\\\\u001f'\x2C\x0d\n];\x0d\n\x0d\nconst escapeFn = (str) => meta[StringPrototypeCharCodeAt(str\x2C 0)];\x0d\n\x0d\nlet warned = false;\x0d\n\x0d\n// The assert module provides functions that throw\x0d\n// AssertionError's when particular conditions are not met. The\x0d\n// assert module must conform to the following interface.\x0d\n\x0d\nconst assert = module.exports = ok;\x0d\n\x0d\nconst NO_EXCEPTION_SENTINEL = {};\x0d\n\x0d\n// All of the following functions must throw an AssertionError\x0d\n// when a corresponding condition is not met\x2C with a message that\x0d\n// may be undefined if not provided. All assertion methods provide\x0d\n// both the actual and expected values to the assertion error for\x0d\n// display purposes.\x0d\n\x0d\nfunction innerFail(obj) {\x0d\n  if (obj.message instanceof Error) throw obj.message;\x0d\n\x0d\n  throw new AssertionError(obj);\x0d\n}\x0d\n\x0d\n/**\x0d\n * @param {any} actual\x0d\n * @param {any} expected\x0d\n * @param {string | Error} [message]\x0d\n * @param {string} [operator]\x0d\n * @param {Function} [stackStartFn]\x0d\n */\x0d\nfunction fail(actual\x2C expected\x2C message\x2C operator\x2C stackStartFn) {\x0d\n  const argsLen = arguments.length;\x0d\n\x0d\n  let internalMessage = false;\x0d\n  if (actual == null && argsLen <= 1) {\x0d\n    internalMessage = true;\x0d\n    message = 'Failed';\x0d\n  } else if (argsLen === 1) {\x0d\n    message = actual;\x0d\n    actual = undefined;\x0d\n  } else {\x0d\n    if (warned === false) {\x0d\n      warned = true;\x0d\n      process.emitWarning(\x0d\n        'assert.fail() with more than one argument is deprecated. ' +\x0d\n          'Please use assert.strictEqual() instead or only pass a message.'\x2C\x0d\n        'DeprecationWarning'\x2C\x0d\n        'DEP0094'\x2C\x0d\n      );\x0d\n    }\x0d\n    if (argsLen === 2)\x0d\n      operator = '!=';\x0d\n  }\x0d\n\x0d\n  if (message instanceof Error) throw message;\x0d\n\x0d\n  const errArgs = {\x0d\n    actual\x2C\x0d\n    expected\x2C\x0d\n    operator: operator === undefined ? 'fail' : operator\x2C\x0d\n    stackStartFn: stackStartFn || fail\x2C\x0d\n    message\x2C\x0d\n  };\x0d\n  const err = new AssertionError(errArgs);\x0d\n  if (internalMessage) {\x0d\n    err.generatedMessage = true;\x0d\n  }\x0d\n  throw err;\x0d\n}\x0d\n\x0d\nassert.fail = fail;\x0d\n\x0d\n// The AssertionError is defined in internal/error.\x0d\nassert.AssertionError = AssertionError;\x0d\n\x0d\nfunction findColumn(fd\x2C column\x2C code) {\x0d\n  if (code.length > column + 100) {\x0d\n    try {\x0d\n      return parseCode(code\x2C column);\x0d\n    } catch {\x0d\n      // End recursion in case no code could be parsed. The expression should\x0d\n      // have been found after 2500 characters\x2C so stop trying.\x0d\n      if (code.length - column > 2500) {\x0d\n        // eslint-disable-next-line no-throw-literal\x0d\n        throw null;\x0d\n      }\x0d\n    }\x0d\n  }\x0d\n  // Read up to 2500 bytes more than necessary in columns. That way we address\x0d\n  // multi byte characters and read enough data to parse the code.\x0d\n  const bytesToRead = column - code.length + 2500;\x0d\n  const buffer = Buffer.allocUnsafe(bytesToRead);\x0d\n  const bytesRead = readSync(fd\x2C buffer\x2C 0\x2C bytesToRead);\x0d\n  code += decoder.write(buffer.slice(0\x2C bytesRead));\x0d\n  // EOF: fast path.\x0d\n  if (bytesRead < bytesToRead) {\x0d\n    return parseCode(code\x2C column);\x0d\n  }\x0d\n  // Read potentially missing code.\x0d\n  return findColumn(fd\x2C column\x2C code);\x0d\n}\x0d\n\x0d\nfunction getCode(fd\x2C line\x2C column) {\x0d\n  let bytesRead = 0;\x0d\n  if (line === 0) {\x0d\n    // Special handle line number one. This is more efficient and simplifies the\x0d\n    // rest of the algorithm. Read more than the regular column number in bytes\x0d\n    // to prevent multiple reads in case multi byte characters are used.\x0d\n    return findColumn(fd\x2C column\x2C '');\x0d\n  }\x0d\n  let lines = 0;\x0d\n  // Prevent blocking the event loop by limiting the maximum amount of\x0d\n  // data that may be read.\x0d\n  let maxReads = 32; // bytesPerRead * maxReads = 512 KiB\x0d\n  const bytesPerRead = 16384;\x0d\n  // Use a single buffer up front that is reused until the call site is found.\x0d\n  let buffer = Buffer.allocUnsafe(bytesPerRead);\x0d\n  while (maxReads-- !== 0) {\x0d\n    // Only allocate a new buffer in case the needed line is found. All data\x0d\n    // before that can be discarded.\x0d\n    buffer = lines < line ? buffer : Buffer.allocUnsafe(bytesPerRead);\x0d\n    bytesRead = readSync(fd\x2C buffer\x2C 0\x2C bytesPerRead);\x0d\n    // Read the buffer until the required code line is found.\x0d\n    for (let i = 0; i < bytesRead; i++) {\x0d\n      if (buffer[i] === 10 && ++lines === line) {\x0d\n        // If the end of file is reached\x2C directly parse the code and return.\x0d\n        if (bytesRead < bytesPerRead) {\x0d\n          return parseCode(buffer.toString('utf8'\x2C i + 1\x2C bytesRead)\x2C column);\x0d\n        }\x0d\n        // Check if the read code is sufficient or read more until the whole\x0d\n        // expression is read. Make sure multi byte characters are preserved\x0d\n        // properly by using the decoder.\x0d\n        const code = decoder.write(buffer.slice(i + 1\x2C bytesRead));\x0d\n        return findColumn(fd\x2C column\x2C code);\x0d\n      }\x0d\n    }\x0d\n  }\x0d\n}\x0d\n\x0d\nfunction parseCode(code\x2C offset) {\x0d\n  // Lazy load acorn.\x0d\n  if (parseExpressionAt === undefined) {\x0d\n    const Parser = require('internal/deps/acorn/acorn/dist/acorn').Parser;\x0d\n    ({ findNodeAround } = require('internal/deps/acorn/acorn-walk/dist/walk'));\x0d\n\x0d\n    parseExpressionAt = FunctionPrototypeBind(Parser.parseExpressionAt\x2C Parser);\x0d\n    tokenizer = FunctionPrototypeBind(Parser.tokenizer\x2C Parser);\x0d\n  }\x0d\n  let node;\x0d\n  let start;\x0d\n  // Parse the read code until the correct expression is found.\x0d\n  for (const token of tokenizer(code\x2C { ecmaVersion: 'latest' })) {\x0d\n    start = token.start;\x0d\n    if (start > offset) {\x0d\n      // No matching expression found. This could happen if the assert\x0d\n      // expression is bigger than the provided buffer.\x0d\n      break;\x0d\n    }\x0d\n    try {\x0d\n      node = parseExpressionAt(code\x2C start\x2C { ecmaVersion: 'latest' });\x0d\n      // Find the CallExpression in the tree.\x0d\n      node = findNodeAround(node\x2C offset\x2C 'CallExpression');\x0d\n      if (node?.node.end >= offset) {\x0d\n        return [\x0d\n          node.node.start\x2C\x0d\n          StringPrototypeReplace(StringPrototypeSlice(code\x2C\x0d\n                                                      node.node.start\x2C node.node.end)\x2C\x0d\n                                 escapeSequencesRegExp\x2C escapeFn)\x2C\x0d\n        ];\x0d\n      }\x0d\n    // eslint-disable-next-line no-unused-vars\x0d\n    } catch (err) {\x0d\n      continue;\x0d\n    }\x0d\n  }\x0d\n  // eslint-disable-next-line no-throw-literal\x0d\n  throw null;\x0d\n}\x0d\n\x0d\nfunction getErrMessage(message\x2C fn) {\x0d\n  const tmpLimit = Error.stackTraceLimit;\x0d\n  const errorStackTraceLimitIsWritable = isErrorStackTraceLimitWritable();\x0d\n  // Make sure the limit is set to 1. Otherwise it could fail (<= 0) or it\x0d\n  // does to much work.\x0d\n  if (errorStackTraceLimitIsWritable) Error.stackTraceLimit = 1;\x0d\n  // We only need the stack trace. To minimize the overhead use an object\x0d\n  // instead of an error.\x0d\n  const err = {};\x0d\n  ErrorCaptureStackTrace(err\x2C fn);\x0d\n  if (errorStackTraceLimitIsWritable) Error.stackTraceLimit = tmpLimit;\x0d\n\x0d\n  ov