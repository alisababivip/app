 if (res.length === 1) {\x0d\n          super(`${base}${res[0].length > 5 ? '\\n\\n' : ' '}${res[0]}`);\x0d\n        } else {\x0d\n          super(`${base}\\n\\n${ArrayPrototypeJoin(res\x2C '\\n')}\\n`);\x0d\n        }\x0d\n      } else {\x0d\n        let res = inspectValue(actual);\x0d\n        let other = inspectValue(expected);\x0d\n        const knownOperator = kReadableOperator[operator];\x0d\n        if (operator === 'notDeepEqual' && res === other) {\x0d\n          res = `${knownOperator}\\n\\n${res}`;\x0d\n          if (res.length > 1024) {\x0d\n            res = `${StringPrototypeSlice(res\x2C 0\x2C 1021)}...`;\x0d\n          }\x0d\n          super(res);\x0d\n        } else {\x0d\n          if (res.length > 512) {\x0d\n            res = `${StringPrototypeSlice(res\x2C 0\x2C 509)}...`;\x0d\n          }\x0d\n          if (other.length > 512) {\x0d\n            other = `${StringPrototypeSlice(other\x2C 0\x2C 509)}...`;\x0d\n          }\x0d\n          if (operator === 'deepEqual') {\x0d\n            res = `${knownOperator}\\n\\n${res}\\n\\nshould loosely deep-equal\\n\\n`;\x0d\n          } else {\x0d\n            const newOp = kReadableOperator[`${operator}Unequal`];\x0d\n            if (newOp) {\x0d\n              res = `${newOp}\\n\\n${res}\\n\\nshould not loosely deep-equal\\n\\n`;\x0d\n            } else {\x0d\n              other = ` ${operator} ${other}`;\x0d\n            }\x0d\n          }\x0d\n          super(`${res}${other}`);\x0d\n        }\x0d\n      }\x0d\n    }\x0d\n\x0d\n    if (isErrorStackTraceLimitWritable()) Error.stackTraceLimit = limit;\x0d\n\x0d\n    this.generatedMessage = !message;\x0d\n    ObjectDefineProperty(this\x2C 'name'\x2C {\x0d\n      __proto__: null\x2C\x0d\n      value: 'AssertionError [ERR_ASSERTION]'\x2C\x0d\n      enumerable: false\x2C\x0d\n      writable: true\x2C\x0d\n      configurable: true\x2C\x0d\n    });\x0d\n    this.code = 'ERR_ASSERTION';\x0d\n    if (details) {\x0d\n      this.actual = undefined;\x0d\n      this.expected = undefined;\x0d\n      this.operator = undefined;\x0d\n      for (let i = 0; i < details.length; i++) {\x0d\n        this['message ' + i] = details[i].message;\x0d\n        this['actual ' + i] = details[i].actual;\x0d\n        this['expected ' + i] = details[i].expected;\x0d\n        this['operator ' + i] = details[i].operator;\x0d\n        this['stack trace ' + i] = details[i].stack;\x0d\n      }\x0d\n    } else {\x0d\n      this.actual = actual;\x0d\n      this.expected = expected;\x0d\n      this.operator = operator;\x0d\n    }\x0d\n    ErrorCaptureStackTrace(this\x2C stackStartFn || stackStartFunction);\x0d\n    // Create error message including the error code in the name.\x0d\n    this.stack; // eslint-disable-line no-unused-expressions\x0d\n    // Reset the name.\x0d\n    this.name = 'AssertionError';\x0d\n  }\x0d\n\x0d\n  toString() {\x0d\n    return `${this.name} [${this.code}]: ${this.message}`;\x0d\n  }\x0d\n\x0d\n  [inspect.custom](recurseTimes\x2C ctx) {\x0d\n    // Long strings should not be fully inspected.\x0d\n    const tmpActual = this.actual;\x0d\n    const tmpExpected = this.expected;\x0d\n\x0d\n    if (typeof this.actual === 'string') {\x0d\n      this.actual = addEllipsis(this.actual);\x0d\n    }\x0d\n    if (typeof this.expected === 'string') {\x0d\n      this.expected = addEllipsis(this.expected);\x0d\n    }\x0d\n\x0d\n    // This limits the `actual` and `expected` property default inspection to\x0d\n    // the minimum depth. Otherwise those values would be too verbose compared\x0d\n    // to the actual error message which contains a combined view of these two\x0d\n    // input values.\x0d\n    const result = inspect(this\x2C {\x0d\n      ...ctx\x2C\x0d\n      customInspect: false\x2C\x0d\n      depth: 0\x2C\x0d\n    });\x0d\n\x0d\n    // Reset the properties after inspection.\x0d\n    this.actual = tmpActual;\x0d\n    this.expected = tmpExpected;\x0d\n\x0d\n    return result;\x0d\n  }\x0d\n}\x0d\n\x0d\nmodule.exports = AssertionError